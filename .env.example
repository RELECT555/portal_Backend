# Я.МЕДИПАЛ — Backend
# Скопируйте как .env и заполните значения

PORT=4000

# Supabase PostgreSQL
# Transaction mode (через pgbouncer, порт 6543) — для приложения
DATABASE_URL=postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
# Session mode (прямое подключение, порт 5432) — для миграций Prisma
DIRECT_URL=postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# Azure AD
AZURE_TENANT_ID=
AZURE_CLIENT_ID=

# Разрешённые origins (фронтенд)
CORS_ORIGINS=http://localhost:3000
